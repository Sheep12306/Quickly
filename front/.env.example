# Quickly AI — Environment Variables
# Copy this file to .env and fill in your values.

# Server Port (default: 3001)
PORT=3001

# Node Environment
NODE_ENV=production

# Optional: Server-side Gemini API Key
# When set, the server provides AI responses even if users haven't configured
# their own API key in the settings page.
# GEMINI_API_KEY=your-gemini-api-key
